{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MSC Taxonomy Schema",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "msc_code": {
        "type": "string",
        "pattern": "^(\\d{2}-(?:\\d{2}|XX)|\\d{2}[A-Z]{1,2}(?:\\d{2}|xx|XX))$"
      },
      "title": {
        "type": "string"
      },
      "title_tex": {
        "type": "string"
      },
      "level": {
        "enum": [
          "section",
          "subsection",
          "item"
        ]
      },
      "hierarchy": {
        "type": "object",
        "properties": {
          "section": {
            "type": "string"
          },
          "subsection": {
            "type": "string"
          }
        },
        "required": [
          "section"
        ],
        "additionalProperties": false
      },
      "description": {
        "type": "string"
      },
      "description_tex": {
        "type": "string"
      },
      "related_msc": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "pillar": {
        "enum": [
          "01_fundamentos_logica",
          "02_estructuras_algebraicas",
          "03_analisis_continuidad",
          "04_espacio_forma",
          "05_discrecion_computacion",
          "06_estocastica_incertidumbre"
        ]
      },
      "primary_pillar": {
        "enum": [
          "01_fundamentos_logica",
          "02_estructuras_algebraicas",
          "03_analisis_continuidad",
          "04_espacio_forma",
          "05_discrecion_computacion",
          "06_estocastica_incertidumbre"
        ]
      },
      "secondary_pillars": {
        "type": "array",
        "items": {
          "enum": [
            "01_fundamentos_logica",
            "02_estructuras_algebraicas",
            "03_analisis_continuidad",
            "04_espacio_forma",
            "05_discrecion_computacion",
            "06_estocastica_incertidumbre"
          ]
        }
      },
      "slug": {
        "type": "string"
      },
      "source_file": {
        "type": "string"
      }
    },
    "required": [
      "msc_code",
      "title",
      "title_tex",
      "level",
      "hierarchy",
      "related_msc",
      "pillar",
      "primary_pillar",
      "secondary_pillars",
      "slug"
    ],
    "additionalProperties": true
  }
}
